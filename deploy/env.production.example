NODE_ENV=production
APP_BASE_URL=https://equalpay.ezag.ai
AUTH_MODE=local

# Generate with:
# openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_32_BYTE_RANDOM_SECRET
FIELD_ENCRYPTION_MASTER_KEY_B64=CHANGE_ME_32_BYTE_BASE64_KEY

# Must match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://paytransparency:CHANGE_ME_POSTGRES_PASSWORD@paytransparency-db:5432/paytransparency
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Cloudflare Zero Trust > Networks > Tunnels > Create tunnel.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_CLOUDFLARE_TUNNEL_TOKEN

# Keep empty for the external VPS test mode without customer Azure access.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_ISSUER=

# Only needed if you intentionally run `npx prisma db seed` in production.
# Do not use local development defaults for external customer tests.
SEED_HR_ADMIN_PASSWORD=
SEED_SYSTEM_ADMIN_PASSWORD=
SEED_SECURITY_ADMIN_PASSWORD=
